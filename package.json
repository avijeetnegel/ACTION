{
  "name": "ACTION",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap-cloud-sdk/resilience": "^4.6.0",
    "@sap/approuter": "^21.3.0",
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.6",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "Northwind": {
        "kind": "odata-v2",
        "model": "srv/external/Northwind",
        "[development]": {
          "credentials": {
            "url": "https://services.odata.org/V2/Northwind/Northwind.svc/"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "Northwind",
            "path": "/V2/Northwind/Northwind.svc/"
          },
          "csrf": true,
          "csrfInBatch": true
        },
        "[hybrid]": {
          "credentials": {
            "path": "/V2/Northwind/Northwind.svc/",
            "destination": "Northwind"
          },
          "csrf": true,
          "csrfInBatch": true
        }
      },
      "auth": {
        "[development]": {
          "kind": "mocked"
        },
        "[production]": {
          "kind": "dummy"
        }
      }
    }
  }
}
