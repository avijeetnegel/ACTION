{
  "xsappname": "ACTION",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Vendor",
      "description": "Vendor access"
    },
    {
      "name": "$XSAPPNAME.Buyer",
      "description": "Buyer access"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "VendorRole",
      "description": "Vendor Role Template",
      "scope-references": [
        "$XSAPPNAME.Vendor"
      ]
    },
    {
      "name": "BuyerRole",
      "description": "Buyer Role Template",
      "scope-references": [
        "$XSAPPNAME.Buyer"
      ]
    },
    {
      "name": "CombinedRole",
      "description": "Vendor/Buyer Role Template",
      "scope-references": [
        "$XSAPPNAME.Vendor",
        "$XSAPPNAME.Buyer"
      ]
    }
  ],
   "oauth2-configuration": {
    "token-validity": 9000,
    "redirect-uris": [
      "https://*.cfapps.us10-001.hana.ondemand.com/login/callback",
      "https://cfapps.us10-001.hana.ondemand.com/**"
    ]
  }
}
